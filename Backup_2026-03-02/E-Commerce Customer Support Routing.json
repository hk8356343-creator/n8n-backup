      "id": "b2c62285-2773-42f4-a3a3-52ff2425e61f",
      "name": "Classify Issue Type",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        144,
        -96
      ],
      "credentials": {
        "openAiApi": {
