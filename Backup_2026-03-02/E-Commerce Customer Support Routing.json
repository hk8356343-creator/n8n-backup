    },
    {
      "parameters": {
        "jsCode": "// Extract issue type and priority from classification\nconst classification = $json.choices[0].message.content;\nconst issueTypes = ['billing', 'shipping', 'returns', 'product_quality', 'account', 'technical', 'general_inquiry'];\nconst priorities = ['critical', 'high', 'medium', 'low'];\n\nlet detectedIssue = 'general_inquiry';\nlet detectedPriority = 'medium';\n\nfor (const type of issueTypes) {\n  if (classification.toLowerCase().includes(type)) {\n    detectedIssue = type;\n    break;\n  }\n}\n\nfor (const priority of priorities) {\n  if (classification.toLowerCase().includes(priority)) {\n    detectedPriority = priority;\n    break;\n  }\n}\n\nreturn {\n  ...item,\n  issue_type: detectedIssue,\n  priority: detectedPriority,\n  sentiment: classification.toLowerCase().includes('angry') || classification.toLowerCase().includes('frustrated') ? 'negative' : 'neutral'\n};"
      },
      "id": "81d3e9e1-90f4-4799-b604-dcb7a0451d4c",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        144,
        48
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.priority }}",
              "operation": "equals",
              "value2": "critical"
            },
            {
              "value1": "={{ $json.priority }}",
              "operation": "equals",
              "value2": "high"
            }
          ]
        }
      },
      "id": "8c26d6ba-5c41-49e4-a89c-962909d408da",
      "name": "Is High Priority?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        320,
        -96
      ]
    },
    {
      "parameters": {
        "jsCode": "// Route to appropriate department\nconst routing = {\n  'billing': 'billing-department@support.company.com',\n  'shipping': 'shipping-department@support.company.com',\n  'returns': 'returns-department@support.company.com',\n  'product_quality': 'quality-team@support.company.com',\n  'account': 'account-support@support.company.com',\n  'technical': 'technical-support@support.company.com',\n  'general_inquiry': 'general-support@support.company.com'\n};\n\nconst escalation = {\n  'critical': true,\n  'high': false,\n  'medium': false,\n  'low': false\n};\n\nreturn {\n  ...item,\n  assigned_to: routing[$json.issue_type] || 'general-support@support.company.com',\n  needs_escalation: escalation[$json.priority],\n  response_time_minutes: $json.priority === 'critical' ? 15 : $json.priority === 'high' ? 60 : $json.priority === 'medium' ? 240 : 1440,\n  auto_response: $json.priority === 'critical' ? 'Critical issue detected. Our team will contact you within 15 minutes.' : 'Thank you for contacting support. We will respond shortly.'\n};"
      },
